---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';

const base = import.meta.env.BASE_URL;

const services = [
  {
    title: 'Automatización de Procesos',
    description: 'Eliminamos tareas repetitivas y optimizamos flujos operativos mediante automatización inteligente que libera a tu equipo para lo que importa.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
    delay: 0,
  },
  {
    title: 'Integración de Sistemas',
    description: 'Conectamos plataformas heterogéneas — CRM, ERP, ecommerce, logística — en un ecosistema unificado que comunica datos en tiempo real.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>',
    delay: 100,
  },
  {
    title: 'Flujos End-to-End',
    description: 'Diseñamos e implementamos flujos de trabajo completos que cubren todo el ciclo operativo, desde la captura de datos hasta la entrega final.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7" /></svg>',
    delay: 200,
  },
  {
    title: 'Data Management',
    description: 'Gobernanza, calidad y gestión estratégica de datos para que tu organización tome decisiones basadas en información confiable y oportuna.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" /></svg>',
    delay: 300,
  },
  {
    title: 'Automatización RPA',
    description: 'Robots de software que replican acciones humanas en sistemas digitales para ejecutar procesos con velocidad, precisión y disponibilidad 24/7.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2v-4M9 21H5a2 2 0 01-2-2v-4m0 0h18" /></svg>',
    delay: 400,
  },
  {
    title: 'Reporting y KPIs',
    description: 'Dashboards operativos y reportes automatizados que transforman datos crudos en inteligencia accionable para la toma de decisiones.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>',
    delay: 500,
  },
];

const metrics = [
  { number: '50+', label: 'Proyectos entregados', icon: '🚀' },
  { number: '30+', label: 'Clientes satisfechos', icon: '🤝' },
  { number: '8+', label: 'Años de experiencia', icon: '⭐' },
  { number: '99%', label: 'Tasa de satisfacción', icon: '✅' },
];

const testimonials = [
  {
    quote: 'ADN Digital Solutions transformó completamente nuestros procesos operativos. La automatización que implementaron redujo nuestros tiempos de procesamiento en un 70%.',
    name: 'María González',
    role: 'CTO — Empresa de Logística',
    initial: 'M',
  },
  {
    quote: 'La integración entre nuestro CRM y sistema de ecommerce que realizó ADN fue impecable. Ahora tenemos visibilidad total de nuestros clientes en tiempo real.',
    name: 'Carlos Rodríguez',
    role: 'Gerente de TI — Retail Corp',
    initial: 'C',
  },
  {
    quote: 'Migramos un sistema legacy de 15 años sin interrumpir operaciones. El equipo de ADN demostró un nivel de profesionalismo y expertise excepcional.',
    name: 'Ana Martínez',
    role: 'Directora de Operaciones — FinTech SA',
    initial: 'A',
  },
];
---

<Layout
  title="ADN Digital Solutions — Automatización, Integración e IT"
  description="Consultoría tecnológica especializada en automatización de procesos, integración de sistemas y transformación digital end-to-end."
>

  <!-- ─── HERO ─────────────────────────────────────────────── -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
    <!-- Background layers -->
    <div class="absolute inset-0 bg-gradient-to-br from-dark via-secondary to-primary"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-cyan/10 via-transparent to-transparent"></div>

    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(#AED8F2 1px, transparent 1px), linear-gradient(90deg, #AED8F2 1px, transparent 1px); background-size: 40px 40px;"></div>

    <!-- Decorative blobs -->
    <div class="absolute top-1/4 right-0 w-96 h-96 bg-cyan/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-1/4 left-0 w-64 h-64 bg-primary/30 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-cyan/30 bg-cyan/5 text-cyan text-xs font-semibold tracking-widest uppercase mb-8 animate-fade-in opacity-0" style="animation-delay: 0.1s; animation-fill-mode: forwards;">
        <span class="w-1.5 h-1.5 rounded-full bg-cyan animate-pulse"></span>
        Consultoría Tecnológica
      </div>

      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight mb-6 animate-fade-in-up opacity-0" style="animation-delay: 0.2s; animation-fill-mode: forwards;">
        Impulsamos tu empresa<br />
        con <span class="bg-gradient-to-r from-accent via-cyan to-accent bg-clip-text text-transparent">
          tecnología inteligente
        </span>
      </h1>

      <!-- Tagline -->
      <p class="text-accent/60 text-sm sm:text-base font-bold tracking-[0.3em] uppercase mb-8 animate-fade-in opacity-0" style="animation-delay: 0.35s; animation-fill-mode: forwards;">
        Automatización — Integración — IT
      </p>

      <!-- Subheadline -->
      <p class="max-w-2xl mx-auto text-accent/80 text-lg sm:text-xl leading-relaxed mb-12 animate-fade-in-up opacity-0" style="animation-delay: 0.4s; animation-fill-mode: forwards;">
        Transformamos procesos operativos, integramos sistemas y digitalizamos flujos
        para que tu organización opere con máxima eficiencia y escalabilidad.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up opacity-0" style="animation-delay: 0.55s; animation-fill-mode: forwards;">
        <a
          href={`${base}contacto/`}
          class="w-full sm:w-auto px-8 py-4 rounded-xl bg-cyan text-dark font-bold text-base hover:bg-accent transition-all duration-300 shadow-xl shadow-cyan/30 hover:shadow-cyan/50 hover:-translate-y-1"
        >
          Solicitar consulta gratuita
        </a>
        <a
          href={`${base}servicios/`}
          class="w-full sm:w-auto px-8 py-4 rounded-xl border border-accent/30 text-accent font-semibold text-base hover:border-cyan hover:text-cyan hover:bg-cyan/5 transition-all duration-300"
        >
          Ver nuestros servicios →
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-fade-in opacity-0" style="animation-delay: 1s; animation-fill-mode: forwards;">
        <span class="text-accent/30 text-xs uppercase tracking-widest">Descubrir</span>
        <div class="w-px h-12 bg-gradient-to-b from-accent/30 to-transparent"></div>
      </div>
    </div>
  </section>

  <!-- ─── SERVICES GRID ─────────────────────────────────────── -->
  <section class="py-20 lg:py-28 bg-dark relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_var(--tw-gradient-stops))] from-primary/20 via-transparent to-transparent pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <!-- Section header -->
      <div class="text-center mb-16">
        <p class="text-cyan text-xs font-bold tracking-[0.3em] uppercase mb-3">Lo que hacemos</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4">
          Nuestros servicios
        </h2>
        <p class="max-w-xl mx-auto text-accent/70 text-base leading-relaxed">
          Soluciones tecnológicas end-to-end diseñadas para resolver los desafíos más complejos de tu operación.
        </p>
      </div>

      <!-- Cards grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            icon={service.icon}
            delay={service.delay}
          />
        ))}
      </div>

      <div class="text-center mt-12">
        <a
          href={`${base}servicios/`}
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-accent/20 text-accent hover:border-cyan hover:text-cyan transition-all duration-200 text-sm font-medium"
        >
          Ver todos los servicios
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── METRICS ───────────────────────────────────────────── -->
  <section class="py-20 bg-secondary relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-cyan/5 via-transparent to-transparent pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-cyan text-xs font-bold tracking-[0.3em] uppercase mb-3">Resultados comprobados</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white">
          Números que nos respaldan
        </h2>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {metrics.map((metric, i) => (
          <div class="text-center group">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-primary/50 border border-cyan/20 mb-4 group-hover:border-cyan/50 group-hover:shadow-lg group-hover:shadow-cyan/10 transition-all duration-300">
              <span class="text-2xl">{metric.icon}</span>
            </div>
            <div class="text-4xl sm:text-5xl font-extrabold text-cyan mb-2 leading-none">
              {metric.number}
            </div>
            <p class="text-accent/70 text-sm font-medium">{metric.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── WHY US ─────────────────────────────────────────────── -->
  <section class="py-20 lg:py-28 bg-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left content -->
        <div>
          <p class="text-cyan text-xs font-bold tracking-[0.3em] uppercase mb-4">Por qué elegirnos</p>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-6 leading-tight">
            Expertos en transformación digital que entienden tu negocio
          </h2>
          <p class="text-accent/70 leading-relaxed mb-8">
            No somos solo consultores tecnológicos — somos socios estratégicos que nos sumergimos en tu operación para entregar soluciones que realmente funcionan y escalan con tu empresa.
          </p>

          <div class="space-y-4">
            {[
              { title: 'Metodología probada', desc: 'Procesos estructurados que minimizan riesgos y maximizan resultados desde el día uno.' },
              { title: 'Equipo especializado', desc: 'Profesionales certificados con experiencia real en proyectos de alta complejidad.' },
              { title: 'Soporte continuo', desc: 'Acompañamiento post-implementación para garantizar el éxito a largo plazo.' },
            ].map((item) => (
              <div class="flex gap-4 p-4 rounded-xl bg-secondary/50 border border-primary/30 hover:border-cyan/30 transition-colors duration-200">
                <div class="w-8 h-8 rounded-lg bg-cyan/10 border border-cyan/30 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div>
                  <h4 class="text-white font-semibold text-sm mb-1">{item.title}</h4>
                  <p class="text-accent/60 text-sm">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right - visual panel -->
        <div class="relative">
          <div class="bg-gradient-to-br from-primary to-secondary rounded-2xl border border-cyan/20 p-8 shadow-2xl shadow-primary/50">
            <!-- Tech stack tags -->
            <p class="text-accent/50 text-xs uppercase tracking-widest mb-4">Tecnologías & Plataformas</p>
            <div class="flex flex-wrap gap-2 mb-8">
              {['Python', 'Node.js', 'REST APIs', 'Salesforce', 'SAP', 'Power Automate', 'UiPath', 'AWS', 'Azure', 'Zapier', 'HubSpot', 'PostgreSQL'].map((tech) => (
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-dark/60 text-accent/80 border border-primary/40">
                  {tech}
                </span>
              ))}
            </div>

            <!-- Process steps -->
            <p class="text-accent/50 text-xs uppercase tracking-widest mb-4">Nuestro proceso</p>
            <div class="space-y-3">
              {[
                { step: '01', label: 'Diagnóstico y análisis' },
                { step: '02', label: 'Diseño de solución' },
                { step: '03', label: 'Implementación ágil' },
                { step: '04', label: 'Pruebas y validación' },
                { step: '05', label: 'Deploy y soporte' },
              ].map((item) => (
                <div class="flex items-center gap-3">
                  <span class="text-cyan/60 font-mono text-xs w-6">{item.step}</span>
                  <div class="flex-1 h-px bg-cyan/20"></div>
                  <span class="text-accent/70 text-sm">{item.label}</span>
                </div>
              ))}
            </div>
          </div>
          <!-- Glow effect -->
          <div class="absolute -inset-1 bg-gradient-to-br from-cyan/20 to-transparent rounded-2xl blur-xl -z-10 opacity-50"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── TESTIMONIALS ──────────────────────────────────────── -->
  <section class="py-20 lg:py-28 bg-secondary relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-primary/20 via-transparent to-transparent pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center mb-16">
        <p class="text-cyan text-xs font-bold tracking-[0.3em] uppercase mb-3">Testimonios</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white">
          Lo que dicen nuestros clientes
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map((t, i) => (
          <div class="bg-dark/60 border border-primary/40 rounded-2xl p-6 hover:border-cyan/30 transition-all duration-300 relative group">
            <!-- Quote icon -->
            <svg class="w-8 h-8 text-cyan/20 mb-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>

            <p class="text-accent/80 text-sm leading-relaxed mb-6 italic">
              "{t.quote}"
            </p>

            <div class="flex items-center gap-3 pt-4 border-t border-primary/30">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-cyan to-primary flex items-center justify-center text-dark font-bold text-sm flex-shrink-0">
                {t.initial}
              </div>
              <div>
                <p class="text-white font-semibold text-sm">{t.name}</p>
                <p class="text-accent/50 text-xs">{t.role}</p>
              </div>
            </div>

            <!-- Stars -->
            <div class="absolute top-6 right-6 flex gap-0.5">
              {[...Array(5)].map(() => (
                <svg class="w-3 h-3 text-cyan/60" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── FINAL CTA ──────────────────────────────────────────── -->
  <section class="relative overflow-hidden py-20 lg:py-28">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-secondary to-dark"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-cyan/15 via-transparent to-transparent"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan/50 to-transparent"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-cyan/80 text-xs font-bold tracking-[0.3em] uppercase mb-4">¿Listo para transformar tu empresa?</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-6 leading-tight">
        Comencemos a construir<br />
        tu solución hoy
      </h2>
      <p class="text-accent/80 text-lg mb-10 max-w-xl mx-auto leading-relaxed">
        Agenda una sesión de diagnóstico gratuita y descubre cómo podemos transformar tus procesos operativos.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`${base}contacto/`}
          class="w-full sm:w-auto px-8 py-4 rounded-xl bg-cyan text-dark font-bold text-base hover:bg-accent transition-all duration-300 shadow-2xl shadow-cyan/30 hover:shadow-cyan/50 hover:-translate-y-1"
        >
          Agenda tu consulta gratuita
        </a>
        <a
          href={`${base}nosotros/`}
          class="w-full sm:w-auto px-8 py-4 rounded-xl border border-accent/30 text-accent font-semibold hover:border-cyan hover:text-cyan transition-all duration-300"
        >
          Conoce el equipo
        </a>
      </div>
    </div>
  </section>

</Layout>
