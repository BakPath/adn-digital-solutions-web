---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const services = [
  {
    title: 'Automatización de Procesos',
    description: 'Analizamos y rediseñamos tus procesos operativos para eliminar tareas manuales repetitivas, minimizar errores humanos y liberar el potencial de tu equipo para actividades de mayor valor estratégico.',
    benefits: [
      'Reducción de tiempos operativos hasta un 80%',
      'Eliminación de errores humanos en procesos críticos',
      'Escalabilidad sin incremento proporcional de recursos',
      'Trazabilidad y auditoría completa de cada proceso',
    ],
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
    color: 'from-cyan/20 to-primary/20',
    tag: 'Core Service',
  },
  {
    title: 'Integración de Sistemas',
    description: 'Conectamos plataformas y aplicaciones heterogéneas para que trabajen como un ecosistema unificado. Desarrollamos integraciones robustas mediante APIs, middleware y conectores personalizados.',
    benefits: [
      'Sincronización de datos en tiempo real entre sistemas',
      'Eliminación de silos de información',
      'Integración con más de 100 plataformas estándar',
      'APIs RESTful y webhooks para conectividad moderna',
    ],
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>',
    color: 'from-primary/20 to-secondary/20',
    tag: 'Core Service',
  },
  {
    title: 'Implementación de Flujos E2E',
    description: 'Diseñamos e implementamos flujos de trabajo completos que cubren el ciclo de vida total de tus procesos, desde la captura inicial de información hasta la entrega final del resultado, garantizando continuidad y eficiencia en cada etapa.',
    benefits: [
      'Mapeo completo del ciclo operativo',
      'Orquestación de múltiples sistemas y actores',
      'Monitoreo y alertas en tiempo real',
      'Diseño orientado a la experiencia del usuario final',
    ],
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 5l7 7-7 7M5 5l7 7-7 7" /></svg>',
    color: 'from-cyan/20 to-secondary/20',
    tag: 'End-to-End',
  },
  {
    title: 'Data Management',
    description: 'Implementamos estrategias integrales de gestión de datos: gobernanza, calidad, catalogación y seguridad. Transformamos datos dispersos en activos estratégicos que impulsan decisiones empresariales informadas.',
    benefits: [
      'Estrategia de Data Governance corporativa',
      'Limpieza y normalización de datos maestros',
      'Catálogo de datos y linaje de información',
      'Cumplimiento con regulaciones de privacidad (GDPR, CCPA)',
    ],
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" /></svg>',
    color: 'from-accent/10 to-primary/20',
    tag: 'Data',
  },
  {
    title: 'Migración de Procesos Legacy',
    description: 'Modernizamos sistemas obsoletos y procesos heredados con estrategias de migración que minimizan la interrupción operativa. Preservamos el conocimiento de negocio mientras adoptamos tecnologías modernas y escalables.',
    benefits: [
      'Análisis y documentación de sistemas existentes',
      'Plan de migración por etapas sin interrupción',
      'Preservación de lógica de negocio crítica',
      'Capacitación del equipo en nuevas plataformas',
    ],
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>',
    color: 'from-secondary/40 to-primary/20',
    tag: 'Modernización',
  },
  {
    title: 'Integraciones con Sistemas Externos',
    description: 'Conectamos tu operación con plataformas CRM, sistemas de logística, marketplaces de ecommerce y ERPs. Creamos el tejido digital que sincroniza tu cadena de valor de forma automática y en tiempo real.',
    benefits: [
      'Integración con Salesforce, HubSpot, SAP y más',
      'Conectores para Shopify, WooCommerce, MercadoLibre',
      'Sincronización de inventario y logística en tiempo real',
      'Dashboards unificados con data cross-platform',
    ],
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>',
    color: 'from-cyan/20 to-primary/30',
    tag: 'Integraciones',
  },
  {
    title: 'Automatización RPA',
    description: 'Desplegamos robots de software (RPA) que replican con precisión las acciones humanas en aplicaciones digitales. Ejecutan procesos repetitivos con velocidad, precisión y disponibilidad 24/7/365.',
    benefits: [
      'Automatización de procesos de back-office',
      'Robots que operan en múltiples aplicaciones simultáneamente',
      'Disponibilidad 24/7 sin costos de turnos adicionales',
      'ROI comprobable desde los primeros meses',
    ],
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2v-4M9 21H5a2 2 0 01-2-2v-4m0 0h18" /></svg>',
    color: 'from-primary/30 to-cyan/10',
    tag: 'RPA',
  },
  {
    title: 'Reporting y KPIs Operativos',
    description: 'Diseñamos dashboards y sistemas de reporting que transforman datos operativos en inteligencia accionable. Monitoreo en tiempo real de métricas críticas para la toma de decisiones estratégicas.',
    benefits: [
      'Dashboards ejecutivos personalizados',
      'KPIs operativos con alertas automáticas',
      'Reportes automatizados en PDF y Excel',
      'Integración con Power BI, Tableau y herramientas BI',
    ],
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>',
    color: 'from-accent/10 to-cyan/10',
    tag: 'Analytics',
  },
  {
    title: 'Conversión y Migración de Datos',
    description: 'Ejecutamos proyectos de migración de datos con metodologías que garantizan integridad, completitud y consistencia. Transformamos y movemos datos entre sistemas preservando la calidad y trazabilidad.',
    benefits: [
      'Migración sin pérdida ni corrupción de datos',
      'Transformación y mapeo de esquemas complejos',
      'Validación y reconciliación post-migración',
      'Rollback garantizado en caso de incidencias',
    ],
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>',
    color: 'from-secondary/40 to-cyan/10',
    tag: 'Data',
  },
  {
    title: 'Mejoras Funcionales y Soporte',
    description: 'Proveemos soporte técnico especializado y mejoras continuas sobre sistemas implementados. Aseguramos la evolución sostenida de tus soluciones digitales conforme crecen las necesidades de tu empresa.',
    benefits: [
      'SLAs de respuesta garantizados',
      'Soporte técnico L1, L2 y L3',
      'Mejoras funcionales ágiles sprint a sprint',
      'Documentación técnica actualizada',
    ],
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" /></svg>',
    color: 'from-primary/30 to-secondary/30',
    tag: 'Soporte',
  },
  {
    title: 'Seguridad y Controles Internos',
    description: 'Implementamos proyectos de seguridad informática y controles internos que protegen los activos digitales de tu empresa. Cumplimiento normativo, auditoría de accesos y gestión de vulnerabilidades.',
    benefits: [
      'Auditorías de seguridad y análisis de vulnerabilidades',
      'Implementación de controles de acceso y privilegios',
      'Marcos de cumplimiento (ISO 27001, SOX, etc.)',
      'Planes de respuesta a incidentes de seguridad',
    ],
    icon: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>',
    color: 'from-cyan/10 to-primary/20',
    tag: 'Seguridad',
  },
];
---

<Layout
  title="Servicios — ADN Digital Solutions"
  description="Portafolio completo de servicios de consultoría tecnológica: automatización, integraciones, RPA, data management, migración de sistemas y más."
>

  <!-- Page Header -->
  <section class="relative pt-28 pb-16 lg:pt-36 lg:pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-dark via-secondary to-primary/40"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-cyan/10 via-transparent to-transparent"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan/30 to-transparent"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-cyan text-xs font-bold tracking-[0.3em] uppercase mb-4 animate-fade-in opacity-0" style="animation-fill-mode: forwards;">Portafolio</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 animate-fade-in-up opacity-0" style="animation-delay: 0.1s; animation-fill-mode: forwards;">
        Nuestros <span class="bg-gradient-to-r from-accent to-cyan bg-clip-text text-transparent">servicios</span>
      </h1>
      <p class="max-w-2xl mx-auto text-accent/70 text-lg leading-relaxed animate-fade-in-up opacity-0" style="animation-delay: 0.2s; animation-fill-mode: forwards;">
        Soluciones tecnológicas integrales para cada etapa de la transformación digital de tu empresa.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 lg:py-24 bg-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {services.map((service, i) => (
          <div class="group bg-secondary/40 border border-primary/40 rounded-2xl p-7 hover:border-cyan/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-cyan/5 animate-fade-in-up opacity-0" style={`animation-delay: ${i * 80}ms; animation-fill-mode: forwards;`}>
            <div class="flex items-start gap-5">
              <!-- Icon -->
              <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${service.color} border border-cyan/20 flex items-center justify-center flex-shrink-0 group-hover:shadow-lg group-hover:shadow-cyan/15 transition-shadow duration-300`}>
                <span class="text-cyan" set:html={service.icon} />
              </div>

              <div class="flex-1 min-w-0">
                <!-- Tag & Title -->
                <div class="flex items-center gap-2 mb-2">
                  <span class="px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-cyan/10 text-cyan/80 border border-cyan/20">
                    {service.tag}
                  </span>
                </div>
                <h3 class="text-white font-bold text-lg mb-3 group-hover:text-cyan transition-colors duration-200">
                  {service.title}
                </h3>
                <p class="text-accent/70 text-sm leading-relaxed mb-5">
                  {service.description}
                </p>

                <!-- Benefits list -->
                <ul class="space-y-2">
                  {service.benefits.map((benefit) => (
                    <li class="flex items-start gap-2.5">
                      <svg class="w-4 h-4 text-cyan flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-accent/60 text-sm">{benefit}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary to-secondary"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-cyan/10 via-transparent to-transparent"></div>

    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">
        ¿Necesitas una solución personalizada?
      </h2>
      <p class="text-accent/80 text-lg mb-8">
        Cuéntanos tu desafío y diseñamos juntos la solución perfecta para tu empresa.
      </p>
      <a
        href={`${base}contacto/`}
        class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-cyan text-dark font-bold text-base hover:bg-accent transition-all duration-300 shadow-xl shadow-cyan/30"
      >
        Hablar con un experto
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

</Layout>
