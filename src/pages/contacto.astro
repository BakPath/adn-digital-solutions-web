---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const contactInfo = [
  {
    label: 'Email',
    value: 'contacto@adndigital.com',
    href: 'mailto:contacto@adndigital.com',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>',
  },
  {
    label: 'Teléfono',
    value: '+1 (234) 567-890',
    href: 'tel:+1234567890',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>',
  },
  {
    label: 'WhatsApp',
    value: '+1 (234) 567-890',
    href: 'https://wa.me/1234567890',
    icon: '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>',
  },
  {
    label: 'Ubicación',
    value: 'Buenos Aires, Argentina',
    href: '#',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
  },
];

const faqs = [
  {
    q: '¿Cuánto tiempo toma un proyecto típico?',
    a: 'Depende del alcance. Un proceso automatizado puede estar listo en 2-4 semanas, mientras que una integración E2E compleja puede tomar 2-4 meses.',
  },
  {
    q: '¿Trabajan con empresas de cualquier tamaño?',
    a: 'Sí. Tenemos experiencia con empresas medianas y grandes. Adaptamos nuestra propuesta de valor al presupuesto y necesidades de cada organización.',
  },
  {
    q: '¿Ofrecen soporte post-implementación?',
    a: 'Absolutamente. Todos nuestros proyectos incluyen un período de garantía y ofrecemos contratos de soporte y mantenimiento continuo.',
  },
  {
    q: '¿En qué países operan?',
    a: 'Operamos principalmente en Argentina, Colombia y Chile, pero trabajamos con clientes en toda América Latina de forma remota.',
  },
];
---

<Layout
  title="Contacto — ADN Digital Solutions"
  description="Ponte en contacto con ADN Digital Solutions. Agenda una consulta gratuita y descubre cómo podemos transformar los procesos tecnológicos de tu empresa."
>

  <!-- Page Header -->
  <section class="relative pt-28 pb-12 lg:pt-36 lg:pb-16 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-dark via-secondary to-primary/40"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-cyan/10 via-transparent to-transparent"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan/30 to-transparent"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-cyan text-xs font-bold tracking-[0.3em] uppercase mb-4 animate-fade-in opacity-0" style="animation-fill-mode: forwards;">Hablemos</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-4 animate-fade-in-up opacity-0" style="animation-delay: 0.1s; animation-fill-mode: forwards;">
        Contáctanos
      </h1>
      <p class="max-w-xl mx-auto text-accent/70 text-lg animate-fade-in-up opacity-0" style="animation-delay: 0.2s; animation-fill-mode: forwards;">
        Cuéntanos tu desafío y agendamos una sesión de diagnóstico sin costo. Respondemos en menos de 24 horas.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-16 lg:py-20 bg-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-10 lg:gap-16">

        <!-- Left: Form -->
        <div class="lg:col-span-3">
          <div class="bg-secondary/40 border border-primary/40 rounded-2xl p-7 lg:p-10">
            <h2 class="text-white font-bold text-2xl mb-2">Envíanos un mensaje</h2>
            <p class="text-accent/60 text-sm mb-8">Completa el formulario y uno de nuestros especialistas se pondrá en contacto contigo.</p>

            <form
              action="https://formspree.io/f/your-form-id"
              method="POST"
              class="space-y-5"
            >
              <div class="grid sm:grid-cols-2 gap-5">
                <!-- Name -->
                <div>
                  <label for="name" class="block text-accent/70 text-xs font-semibold uppercase tracking-wider mb-2">
                    Nombre completo <span class="text-cyan">*</span>
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    placeholder="Juan García"
                    class="w-full px-4 py-3 rounded-xl bg-dark/60 border border-primary/50 text-white placeholder:text-accent/30 focus:outline-none focus:border-cyan/50 focus:ring-1 focus:ring-cyan/30 transition-all duration-200 text-sm"
                  />
                </div>

                <!-- Email -->
                <div>
                  <label for="email" class="block text-accent/70 text-xs font-semibold uppercase tracking-wider mb-2">
                    Email <span class="text-cyan">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    placeholder="juan@empresa.com"
                    class="w-full px-4 py-3 rounded-xl bg-dark/60 border border-primary/50 text-white placeholder:text-accent/30 focus:outline-none focus:border-cyan/50 focus:ring-1 focus:ring-cyan/30 transition-all duration-200 text-sm"
                  />
                </div>
              </div>

              <!-- Company -->
              <div>
                <label for="company" class="block text-accent/70 text-xs font-semibold uppercase tracking-wider mb-2">
                  Empresa
                </label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  placeholder="Mi Empresa S.A."
                  class="w-full px-4 py-3 rounded-xl bg-dark/60 border border-primary/50 text-white placeholder:text-accent/30 focus:outline-none focus:border-cyan/50 focus:ring-1 focus:ring-cyan/30 transition-all duration-200 text-sm"
                />
              </div>

              <!-- Service -->
              <div>
                <label for="service" class="block text-accent/70 text-xs font-semibold uppercase tracking-wider mb-2">
                  Servicio de interés
                </label>
                <select
                  id="service"
                  name="service"
                  class="w-full px-4 py-3 rounded-xl bg-dark/60 border border-primary/50 text-accent/80 focus:outline-none focus:border-cyan/50 focus:ring-1 focus:ring-cyan/30 transition-all duration-200 text-sm appearance-none cursor-pointer"
                >
                  <option value="">Selecciona un servicio</option>
                  <option value="automatizacion">Automatización de Procesos</option>
                  <option value="integracion">Integración de Sistemas</option>
                  <option value="e2e">Flujos End-to-End</option>
                  <option value="data">Data Management</option>
                  <option value="migracion">Migración Legacy</option>
                  <option value="rpa">Automatización RPA</option>
                  <option value="reporting">Reporting y KPIs</option>
                  <option value="seguridad">Seguridad y Controles</option>
                  <option value="otro">Otro</option>
                </select>
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-accent/70 text-xs font-semibold uppercase tracking-wider mb-2">
                  Mensaje <span class="text-cyan">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  placeholder="Cuéntanos sobre tu proyecto o desafío tecnológico..."
                  class="w-full px-4 py-3 rounded-xl bg-dark/60 border border-primary/50 text-white placeholder:text-accent/30 focus:outline-none focus:border-cyan/50 focus:ring-1 focus:ring-cyan/30 transition-all duration-200 text-sm resize-none"
                ></textarea>
              </div>

              <!-- Submit -->
              <button
                type="submit"
                class="w-full py-4 rounded-xl bg-cyan text-dark font-bold text-base hover:bg-accent transition-all duration-300 shadow-xl shadow-cyan/20 hover:shadow-cyan/40 hover:-translate-y-0.5 flex items-center justify-center gap-2"
              >
                Enviar mensaje
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </button>

              <p class="text-accent/40 text-xs text-center">
                Al enviar este formulario aceptas nuestra política de privacidad. Respondemos en menos de 24 horas hábiles.
              </p>
            </form>
          </div>
        </div>

        <!-- Right: Contact Info + Map -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Contact cards -->
          <div class="space-y-3">
            <h2 class="text-white font-bold text-xl mb-5">Información de contacto</h2>
            {contactInfo.map((info) => (
              <a
                href={info.href}
                class="flex items-center gap-4 p-4 rounded-xl bg-secondary/40 border border-primary/40 hover:border-cyan/40 hover:bg-secondary/60 transition-all duration-200 group"
              >
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-primary to-secondary border border-cyan/20 flex items-center justify-center flex-shrink-0 group-hover:shadow-lg group-hover:shadow-cyan/15 transition-shadow">
                  <span class="text-cyan" set:html={info.icon} />
                </div>
                <div>
                  <p class="text-accent/40 text-xs uppercase tracking-wider mb-0.5">{info.label}</p>
                  <p class="text-white text-sm font-medium group-hover:text-cyan transition-colors">{info.value}</p>
                </div>
              </a>
            ))}
          </div>

          <!-- Map placeholder -->
          <div class="rounded-2xl overflow-hidden border border-primary/40 bg-secondary/30">
            <div class="relative h-48 bg-gradient-to-br from-primary/40 to-secondary/60 flex flex-col items-center justify-center">
              <!-- Decorative grid -->
              <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(#AED8F2 1px, transparent 1px), linear-gradient(90deg, #AED8F2 1px, transparent 1px); background-size: 20px 20px;"></div>

              <!-- Pin icon -->
              <div class="relative z-10 flex flex-col items-center gap-3">
                <div class="w-14 h-14 rounded-full bg-gradient-to-br from-cyan to-primary flex items-center justify-center shadow-xl shadow-cyan/30">
                  <svg class="w-7 h-7 text-dark" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                  </svg>
                </div>
                <div class="text-center">
                  <p class="text-white font-semibold text-sm">Buenos Aires, Argentina</p>
                  <p class="text-accent/60 text-xs">Piso 8, Torre Catalinas Norte</p>
                </div>
              </div>
            </div>
            <div class="p-4 bg-dark/40">
              <p class="text-accent/50 text-xs text-center">
                También operamos en Colombia y Chile · Trabajo remoto disponible
              </p>
            </div>
          </div>

          <!-- Business hours -->
          <div class="bg-secondary/40 border border-primary/40 rounded-xl p-5">
            <h3 class="text-white font-semibold text-sm mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Horario de atención
            </h3>
            <div class="space-y-2">
              {[
                { day: 'Lunes — Viernes', hours: '9:00 — 18:00 ART' },
                { day: 'Sábados', hours: '10:00 — 14:00 ART' },
                { day: 'Domingos', hours: 'Cerrado' },
              ].map((item) => (
                <div class="flex justify-between items-center text-sm">
                  <span class="text-accent/60">{item.day}</span>
                  <span class="text-white font-medium">{item.hours}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-secondary relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,_var(--tw-gradient-stops))] from-primary/20 via-transparent to-transparent pointer-events-none"></div>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center mb-12">
        <p class="text-cyan text-xs font-bold tracking-[0.3em] uppercase mb-3">FAQ</p>
        <h2 class="text-3xl font-extrabold text-white">Preguntas frecuentes</h2>
      </div>

      <div class="space-y-4">
        {faqs.map((faq, i) => (
          <details class="group bg-dark/60 border border-primary/40 rounded-xl overflow-hidden hover:border-cyan/30 transition-colors">
            <summary class="flex items-center justify-between gap-4 p-5 cursor-pointer list-none">
              <span class="text-white font-medium text-sm">{faq.q}</span>
              <svg class="w-4 h-4 text-cyan flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5">
              <p class="text-accent/70 text-sm leading-relaxed border-t border-primary/30 pt-4">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

</Layout>
