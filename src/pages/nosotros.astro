---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const values = [
  {
    title: 'Excelencia técnica',
    description: 'Nos comprometemos con los más altos estándares de calidad en cada solución que entregamos, sin atajos ni compromisos.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>',
  },
  {
    title: 'Orientación al cliente',
    description: 'Tu éxito es nuestro éxito. Escuchamos, entendemos y nos adaptamos a las necesidades específicas de cada cliente.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
  },
  {
    title: 'Innovación continua',
    description: 'Exploramos y adoptamos tecnologías emergentes para ofrecer soluciones que no solo resuelven el presente sino que preparan el futuro.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>',
  },
  {
    title: 'Transparencia',
    description: 'Comunicación clara, honesta y directa en cada etapa del proyecto. Sin sorpresas, sin letra chica.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>',
  },
  {
    title: 'Responsabilidad',
    description: 'Cumplimos los compromisos que asumimos. Si algo no va como se planeó, lo resolvemos juntos sin excusas.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>',
  },
  {
    title: 'Colaboración',
    description: 'Trabajamos como extensión del equipo de nuestros clientes, compartiendo conocimiento y construyendo capacidades internas.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>',
  },
];

const team = [
  {
    name: 'Alejandro Mendoza',
    role: 'CEO & Fundador',
    bio: 'Más de 15 años liderando proyectos de transformación digital en empresas Fortune 500. Especialista en arquitectura de sistemas y automatización empresarial.',
    initial: 'AM',
    color: 'from-cyan to-primary',
  },
  {
    name: 'Valentina Torres',
    role: 'CTO',
    bio: 'Arquitecta de soluciones con expertise en integraciones cloud, microservicios y plataformas de automatización. Certificada en AWS, Azure y GCP.',
    initial: 'VT',
    color: 'from-primary to-secondary',
  },
  {
    name: 'Diego Fernández',
    role: 'Líder de Automatización RPA',
    bio: 'Experto certificado en UiPath, Automation Anywhere y Power Automate. Ha implementado más de 200 procesos RPA en diversas industrias.',
    initial: 'DF',
    color: 'from-secondary to-cyan/60',
  },
  {
    name: 'Lucía Ramírez',
    role: 'Data & Analytics Lead',
    bio: 'Especialista en data engineering, BI y analítica avanzada. Transforma datos en estrategia para organizaciones data-driven.',
    initial: 'LR',
    color: 'from-cyan/60 to-primary',
  },
  {
    name: 'Martín Álvarez',
    role: 'Líder de Integraciones',
    bio: 'Desarrollador senior con profundo conocimiento en APIs, middleware y conectores para plataformas CRM, ERP y ecommerce.',
    initial: 'MA',
    color: 'from-primary/80 to-cyan',
  },
  {
    name: 'Sofía Ibáñez',
    role: 'Project Manager',
    bio: 'PMP certificada con amplia experiencia en gestión de proyectos tecnológicos complejos, metodologías ágiles y gestión del cambio.',
    initial: 'SI',
    color: 'from-accent/40 to-primary',
  },
];

const milestones = [
  { year: '2016', event: 'Fundación de ADN Digital Solutions en Buenos Aires.' },
  { year: '2018', event: 'Primeros 10 clientes corporativos y expansión del equipo.' },
  { year: '2020', event: 'Lanzamiento de la práctica de RPA y automatización inteligente.' },
  { year: '2022', event: 'Apertura de operaciones en Colombia y Chile.' },
  { year: '2024', event: 'Superamos los 50 proyectos entregados y 30 clientes activos.' },
  { year: '2025', event: 'Expansión de la práctica de IA aplicada a procesos de negocio.' },
];
---

<Layout
  title="Nosotros — ADN Digital Solutions"
  description="Conoce la historia, misión, valores y el equipo detrás de ADN Digital Solutions, tu socio estratégico en transformación tecnológica."
>

  <!-- Page Header -->
  <section class="relative pt-28 pb-16 lg:pt-36 lg:pb-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-dark via-secondary to-primary/40"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,_var(--tw-gradient-stops))] from-cyan/10 via-transparent to-transparent"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan/30 to-transparent"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-cyan text-xs font-bold tracking-[0.3em] uppercase mb-4 animate-fade-in opacity-0" style="animation-fill-mode: forwards;">Quiénes somos</p>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight animate-fade-in-up opacity-0" style="animation-delay: 0.1s; animation-fill-mode: forwards;">
            Tecnología al servicio de tu <span class="bg-gradient-to-r from-accent to-cyan bg-clip-text text-transparent">crecimiento</span>
          </h1>
          <p class="text-accent/70 text-lg leading-relaxed animate-fade-in-up opacity-0" style="animation-delay: 0.2s; animation-fill-mode: forwards;">
            Somos una consultora tecnológica especializada en automatización, integración de sistemas y transformación digital. Desde 2016, acompañamos a empresas latinoamericanas en su evolución hacia la eficiencia operativa y la competitividad digital.
          </p>
        </div>

        <!-- Stats panel -->
        <div class="grid grid-cols-2 gap-4 animate-fade-in-up opacity-0" style="animation-delay: 0.3s; animation-fill-mode: forwards;">
          {[
            { n: '8+', l: 'Años de trayectoria' },
            { n: '50+', l: 'Proyectos exitosos' },
            { n: '30+', l: 'Clientes activos' },
            { n: '3', l: 'Países de operación' },
          ].map((s) => (
            <div class="bg-primary/30 border border-cyan/20 rounded-2xl p-6 text-center">
              <div class="text-4xl font-extrabold text-cyan mb-1">{s.n}</div>
              <p class="text-accent/70 text-sm">{s.l}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="py-20 lg:py-24 bg-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-cyan text-xs font-bold tracking-[0.3em] uppercase mb-3">Nuestra brújula</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white">Misión, Visión y Propósito</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Mission -->
        <div class="bg-gradient-to-br from-primary to-secondary border border-cyan/20 rounded-2xl p-7 hover:border-cyan/40 transition-all duration-300 hover:-translate-y-1 group">
          <div class="w-12 h-12 rounded-xl bg-cyan/10 border border-cyan/30 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-cyan font-bold text-xs uppercase tracking-widest mb-3">Misión</h3>
          <p class="text-white font-semibold text-lg mb-3 leading-snug">Potenciar la eficiencia operativa</p>
          <p class="text-accent/70 text-sm leading-relaxed">
            Entregar soluciones tecnológicas que transformen los procesos de nuestros clientes, generando valor medible, escalable y sostenible mediante automatización e integración inteligente.
          </p>
        </div>

        <!-- Vision -->
        <div class="bg-gradient-to-br from-secondary to-primary/80 border border-cyan/20 rounded-2xl p-7 hover:border-cyan/40 transition-all duration-300 hover:-translate-y-1 md:mt-4 group">
          <div class="w-12 h-12 rounded-xl bg-cyan/10 border border-cyan/30 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
          </div>
          <h3 class="text-cyan font-bold text-xs uppercase tracking-widest mb-3">Visión</h3>
          <p class="text-white font-semibold text-lg mb-3 leading-snug">Liderar la transformación digital</p>
          <p class="text-accent/70 text-sm leading-relaxed">
            Ser la consultora tecnológica de referencia en América Latina, reconocida por la calidad de nuestras soluciones, el talento de nuestro equipo y el impacto real en los negocios de nuestros clientes.
          </p>
        </div>

        <!-- Purpose -->
        <div class="bg-gradient-to-br from-primary to-dark border border-cyan/20 rounded-2xl p-7 hover:border-cyan/40 transition-all duration-300 hover:-translate-y-1 group">
          <div class="w-12 h-12 rounded-xl bg-cyan/10 border border-cyan/30 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="text-cyan font-bold text-xs uppercase tracking-widest mb-3">Propósito</h3>
          <p class="text-white font-semibold text-lg mb-3 leading-snug">Construir el futuro digital</p>
          <p class="text-accent/70 text-sm leading-relaxed">
            Creemos que la tecnología bien aplicada libera el potencial humano. Nuestro propósito es que cada empresa que trabaje con nosotros opere con mayor libertad, agilidad e inteligencia.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 lg:py-24 bg-secondary relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,_var(--tw-gradient-stops))] from-cyan/5 via-transparent to-transparent pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center mb-16">
        <p class="text-cyan text-xs font-bold tracking-[0.3em] uppercase mb-3">Lo que nos define</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white">Nuestros valores</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {values.map((value, i) => (
          <div class="bg-dark/60 border border-primary/40 rounded-2xl p-6 hover:border-cyan/30 hover:-translate-y-1 transition-all duration-300 group animate-fade-in-up opacity-0" style={`animation-delay: ${i * 100}ms; animation-fill-mode: forwards;`}>
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-primary to-secondary border border-cyan/20 flex items-center justify-center mb-4 group-hover:shadow-lg group-hover:shadow-cyan/10 transition-shadow">
              <span class="text-cyan" set:html={value.icon} />
            </div>
            <h3 class="text-white font-semibold text-base mb-2">{value.title}</h3>
            <p class="text-accent/60 text-sm leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- History Timeline -->
  <section class="py-20 lg:py-24 bg-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-cyan text-xs font-bold tracking-[0.3em] uppercase mb-3">Nuestra trayectoria</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white">Historia y evolución</h2>
      </div>

      <div class="relative">
        <!-- Timeline line -->
        <div class="absolute left-4 lg:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-cyan/40 via-primary/30 to-transparent"></div>

        <div class="space-y-8">
          {milestones.map((m, i) => (
            <div class={`relative flex gap-6 lg:gap-8 ${i % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} pl-12 lg:pl-0`}>
              <!-- Dot -->
              <div class="absolute left-0 lg:left-1/2 lg:-translate-x-1/2 w-8 h-8 rounded-full bg-gradient-to-br from-cyan to-primary border-2 border-dark flex items-center justify-center z-10 top-0">
                <div class="w-2 h-2 rounded-full bg-white"></div>
              </div>

              <!-- Year -->
              <div class={`hidden lg:flex lg:w-1/2 items-start ${i % 2 === 0 ? 'justify-end pr-10' : 'justify-start pl-10'}`}>
                <span class="text-cyan font-black text-2xl">{m.year}</span>
              </div>

              <!-- Content -->
              <div class={`lg:w-1/2 ${i % 2 === 0 ? 'lg:pl-10' : 'lg:pr-10'}`}>
                <div class="bg-secondary/60 border border-primary/40 rounded-xl p-4 hover:border-cyan/30 transition-colors">
                  <p class="text-cyan font-bold text-sm mb-1 lg:hidden">{m.year}</p>
                  <p class="text-accent/80 text-sm leading-relaxed">{m.event}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-20 lg:py-24 bg-secondary relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,_var(--tw-gradient-stops))] from-primary/20 via-transparent to-transparent pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center mb-16">
        <p class="text-cyan text-xs font-bold tracking-[0.3em] uppercase mb-3">Las personas detrás</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">Nuestro equipo</h2>
        <p class="max-w-xl mx-auto text-accent/70 text-base">
          Profesionales apasionados por la tecnología y comprometidos con el éxito de cada proyecto.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {team.map((member, i) => (
          <div class="group bg-dark/60 border border-primary/40 rounded-2xl p-6 hover:border-cyan/40 hover:-translate-y-1.5 transition-all duration-300 hover:shadow-xl hover:shadow-cyan/10 text-center animate-fade-in-up opacity-0" style={`animation-delay: ${i * 100}ms; animation-fill-mode: forwards;`}>
            <!-- Avatar -->
            <div class={`w-20 h-20 rounded-2xl bg-gradient-to-br ${member.color} flex items-center justify-center mx-auto mb-4 shadow-lg group-hover:shadow-xl transition-shadow`}>
              <span class="text-2xl font-black text-white/90">{member.initial}</span>
            </div>

            <h3 class="text-white font-bold text-lg mb-0.5">{member.name}</h3>
            <p class="text-cyan text-xs font-semibold uppercase tracking-wider mb-3">{member.role}</p>
            <p class="text-accent/60 text-sm leading-relaxed">{member.bio}</p>

            <!-- Social placeholder -->
            <div class="flex items-center justify-center gap-2 mt-4 pt-4 border-t border-primary/30">
              <a href="#" class="w-8 h-8 rounded-lg bg-primary/40 flex items-center justify-center text-accent/60 hover:text-cyan hover:bg-primary transition-all">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary to-secondary"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-cyan/10 via-transparent to-transparent"></div>

    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">
        ¿Quieres ser parte de nuestra historia?
      </h2>
      <p class="text-accent/80 text-lg mb-8">
        Trabajamos con empresas que buscan crecer de forma inteligente. Hablemos.
      </p>
      <a
        href={`${base}contacto/`}
        class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-cyan text-dark font-bold text-base hover:bg-accent transition-all duration-300 shadow-xl shadow-cyan/30"
      >
        Contáctanos hoy
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

</Layout>
