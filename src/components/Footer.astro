---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="bg-secondary border-t border-primary/40">
  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href={base} class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-cyan to-primary flex items-center justify-center">
            <span class="text-dark font-black text-sm">ADN</span>
          </div>
          <div class="flex flex-col leading-none">
            <span class="font-bold text-white text-sm">ADN Digital</span>
            <span class="text-accent text-[10px] font-medium tracking-widest uppercase">Solutions</span>
          </div>
        </a>
        <p class="text-accent/70 text-sm leading-relaxed mb-6">
          Transformamos empresas a través de automatización inteligente, integración de sistemas y tecnología de punta.
        </p>
        <!-- Social Links -->
        <div class="flex items-center gap-3">
          <a href="#" aria-label="LinkedIn" class="w-9 h-9 rounded-lg bg-primary/50 flex items-center justify-center text-accent/70 hover:text-cyan hover:bg-primary transition-all duration-200">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="#" aria-label="Twitter / X" class="w-9 h-9 rounded-lg bg-primary/50 flex items-center justify-center text-accent/70 hover:text-cyan hover:bg-primary transition-all duration-200">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.736l7.73-8.835L1.254 2.25H8.08l4.258 5.63 5.906-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="#" aria-label="GitHub" class="w-9 h-9 rounded-lg bg-primary/50 flex items-center justify-center text-accent/70 hover:text-cyan hover:bg-primary transition-all duration-200">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Services column -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Servicios</h3>
        <ul class="space-y-2.5">
          {[
            'Automatización de Procesos',
            'Integraciones de Sistemas',
            'Flujos End-to-End',
            'Data Management',
            'Migración Legacy',
            'Automatización RPA',
          ].map((service) => (
            <li>
              <a href={`${base}servicios`} class="text-accent/60 hover:text-cyan text-sm transition-colors duration-200 flex items-center gap-1.5">
                <span class="w-1 h-1 rounded-full bg-cyan/50 flex-shrink-0"></span>
                {service}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company column -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Empresa</h3>
        <ul class="space-y-2.5">
          {[
            { label: 'Nosotros', href: `${base}nosotros` },
            { label: 'Servicios', href: `${base}servicios` },
            { label: 'Casos de éxito', href: `${base}nosotros` },
            { label: 'Contacto', href: `${base}contacto` },
          ].map((link) => (
            <li>
              <a href={link.href} class="text-accent/60 hover:text-cyan text-sm transition-colors duration-200 flex items-center gap-1.5">
                <span class="w-1 h-1 rounded-full bg-cyan/50 flex-shrink-0"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Contacto</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-primary/50 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-accent/40 text-xs uppercase tracking-wider mb-0.5">Email</p>
              <a href="mailto:contacto@adndigital.com" class="text-accent/70 hover:text-cyan text-sm transition-colors">contacto@adndigital.com</a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-primary/50 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-accent/40 text-xs uppercase tracking-wider mb-0.5">Teléfono</p>
              <a href="tel:+1234567890" class="text-accent/70 hover:text-cyan text-sm transition-colors">+1 (234) 567-890</a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-primary/50 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-accent/40 text-xs uppercase tracking-wider mb-0.5">Ubicación</p>
              <p class="text-accent/70 text-sm">Buenos Aires, Argentina</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-primary/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-accent/40 text-xs">
        &copy; {year} ADN Digital Solutions. Todos los derechos reservados.
      </p>
      <p class="text-accent/40 text-xs">
        Automatización · Integración · IT
      </p>
    </div>
  </div>
</footer>
