---
const base = import.meta.env.BASE_URL;

const navLinks = [
  { href: `${base}`, label: 'Inicio' },
  { href: `${base}servicios`, label: 'Servicios' },
  { href: `${base}nosotros`, label: 'Nosotros' },
  { href: `${base}contacto`, label: 'Contacto' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-dark/90 backdrop-blur-md border-b border-primary/30">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href={base} class="flex items-center gap-3 group">
        <div class="w-9 h-9 lg:w-11 lg:h-11 rounded-lg bg-gradient-to-br from-cyan to-primary flex items-center justify-center shadow-lg shadow-cyan/20 group-hover:shadow-cyan/40 transition-shadow duration-300">
          <span class="text-dark font-black text-sm lg:text-base tracking-tight">ADN</span>
        </div>
        <div class="flex flex-col leading-none">
          <span class="font-bold text-white text-sm lg:text-base">ADN Digital</span>
          <span class="text-accent text-[10px] lg:text-xs font-medium tracking-widest uppercase">Solutions</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200
              ${currentPath === link.href || (link.href !== base && currentPath.startsWith(link.href))
                ? 'text-cyan bg-primary/40'
                : 'text-accent/80 hover:text-white hover:bg-primary/20'
              }`}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center gap-4">
        <a
          href={`${base}contacto`}
          class="px-5 py-2.5 rounded-lg bg-cyan text-dark font-semibold text-sm hover:bg-accent transition-all duration-200 shadow-lg shadow-cyan/25 hover:shadow-cyan/40 hover:-translate-y-0.5"
        >
          Solicitar consulta
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="menu-btn"
        class="lg:hidden p-2 rounded-lg text-accent hover:text-white hover:bg-primary/30 transition-colors"
        aria-label="Abrir menú"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-primary/30 mt-0">
      <div class="flex flex-col gap-1 pt-4">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200
              ${currentPath === link.href || (link.href !== base && currentPath.startsWith(link.href))
                ? 'text-cyan bg-primary/40'
                : 'text-accent/80 hover:text-white hover:bg-primary/20'
              }`}
          >
            {link.label}
          </a>
        ))}
        <a
          href={`${base}contacto`}
          class="mt-2 px-4 py-3 rounded-lg bg-cyan text-dark font-semibold text-sm text-center hover:bg-accent transition-colors"
        >
          Solicitar consulta
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
